<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eye Cloud System</title>
<style>
body{margin:0;overflow:hidden;background:rgb(182,217,219)}
canvas{display:block}
#refreshBtn{position:fixed;top:10px;right:10px;padding:8px 12px;font-size:14px;z-index:10}
</style>
</head>
<body>
<button id="refreshBtn">Refresh</button>
<canvas id="c"></canvas>
<script>

/* ================= BASIC ================= */

const canvas=document.getElementById("c")
const ctx=canvas.getContext("2d")

function resize(){
 canvas.width=innerWidth
 canvas.height=innerHeight
}

window.addEventListener("resize",resize)
resize()

let mouse={x:0,y:0,down:false}

/* ================= COLOR ================= */

const COLORS={
 cloud:"rgb(244,250,238)",
 eyelid:"rgb(89,122,155)",
 outline:"rgb(42,56,86)",
 particle:"rgba(255,255,220,1)",
 pupil:"#4da6ff"
}

/* ================= SYSTEM STATE ================= */

let eye=null
let clouds=[]
let orbitClouds=[]
let particles=[]
let stars=[]

let eyeClicks=0
let orbitTimer=0
let orbitActive=true

let cloudSpawnTimer=0

/* ================= UTILS ================= */

function maxCloudCount(){
 let area=canvas.width*canvas.height
 return Math.floor(area/30000)
}

/* ================= CLOUD ================= */

class Cloud{
 constructor(x,y,r){

  this.x=x
  this.y=y

  this.homeX=x
  this.homeY=y

  this.r=r

  const a=Math.random()*Math.PI*2
  const s=0.6+Math.random()*0.6

  this.vx=Math.cos(a)*s
  this.vy=Math.sin(a)*s

  this.baseVX=this.vx
  this.baseVY=this.vy

  this.alpha=1
  this.fade=false

  this.returnTimer=0
 }

 update(){

  this.x+=this.vx
  this.y+=this.vy

  this.vx+=(this.baseVX-this.vx)*0.02
  this.vy+=(this.baseVY-this.vy)*0.02

  if(!mouse.down) this.returnTimer++
  else this.returnTimer=0

  if(this.returnTimer>60){

   this.x+=(this.homeX-this.x)*0.02
   this.y+=(this.homeY-this.y)*0.02

  }

  if(this.fade) this.alpha-=0.01
 }

 draw(){

  ctx.globalAlpha=this.alpha

  ctx.fillStyle=COLORS.cloud

  ctx.beginPath()
  ctx.arc(this.x,this.y,this.r,0,Math.PI*2)
  ctx.fill()

  ctx.globalAlpha=1
 }
}

/* ================= ORBIT CLOUD ================= */

class OrbitCloud{

 constructor(angle){

  this.angle=angle
  this.orbitRadius=80

  this.size=10
  this.baseSize=60

  this.scale=1
  this.speed=0.21

  this.offsetX=0
  this.offsetY=0
 }

 update(){

  if(orbitActive){

   orbitTimer++
   this.angle+=this.speed

   if(orbitTimer>90){
    orbitActive=false
   }

  } else {

   /* spiral inward from 80 → 70 while slowing */
   this.orbitRadius += (70 - this.orbitRadius) * 0.05

   if(this.size < this.baseSize){
    this.size += 0.6
   }

   this.speed *= 0.97
   this.angle += this.speed

   if(this.speed < 0.002){

    this.speed = 0

    if(this.offsetX === 0 && this.offsetY === 0){
     this.offsetX = Math.cos(this.angle) * this.orbitRadius
     this.offsetY = Math.sin(this.angle) * this.orbitRadius
    }

   }
  }

  /* position update */

  if(this.speed === 0){
   this.x = eye.x + this.offsetX
   this.y = eye.y + this.offsetY
  } else {
   this.x = eye.x + Math.cos(this.angle) * this.orbitRadius
   this.y = eye.y + Math.sin(this.angle) * this.orbitRadius
  }

  /* mouse scaling */

  if(mouse.down){
   this.scale += (1.3 - this.scale) * 0.05
  } else {
   this.scale += (1 - this.scale) * 0.2
  }
 }

 draw(){

  ctx.fillStyle = COLORS.cloud

  ctx.beginPath()
  ctx.arc(this.x,this.y,this.size*this.scale,0,Math.PI*2)
  ctx.fill()
 }
}

/* ================= PARTICLES ================= */

class Particle{

 constructor(x,y){

  this.x=x
  this.y=y

  const a=Math.random()*Math.PI*2
  const s=Math.random()*4

  this.vx=Math.cos(a)*s
  this.vy=Math.sin(a)*s

  this.life=60

 }

 update(){

  this.x+=this.vx
  this.y+=this.vy

  this.vx*=0.96
  this.vy*=0.96

  this.life--

 }

 draw(){

  ctx.globalAlpha=this.life/60

  ctx.fillStyle=COLORS.particle

  ctx.beginPath()
  ctx.arc(this.x,this.y,2,0,Math.PI*2)
  ctx.fill()

  ctx.globalAlpha=1

 }
}

class Star{

 constructor(x,y,a){

  this.x=x
  this.y=y

  this.vx=Math.cos(a)*5
  this.vy=Math.sin(a)*5

  this.life=40

 }

 update(){

  this.x+=this.vx
  this.y+=this.vy

  this.life--

 }

 draw(){

  ctx.globalAlpha=this.life/40

  ctx.fillStyle="white"

  ctx.beginPath()
  ctx.arc(this.x,this.y,3,0,Math.PI*2)
  ctx.fill()

  ctx.globalAlpha=1

 }
}

/* ================= EYE ================= */

class Eye{

 constructor(){

  this.x=canvas.width/2
  this.y=canvas.height/2

  this.radius=40

  this.vx=0
  this.vy=0

  this.lid=1

  this.pupilBase=30
  this.pupil=this.pupilBase

  this.pupilAnim=0

 }

 update(){

  this.x+=this.vx
  this.y+=this.vy

  this.vx*=0.95
  this.vy*=0.95

  /* faster opening */

  if(this.lid>0){

   this.lid-=0.06

   if(this.lid<0) this.lid=0

  }

  if(this.pupilAnim>0){

   this.pupilAnim--

   this.pupil=15

  }

  else{

   this.pupil=this.pupilBase

  }

 }

 draw(){

  ctx.lineWidth=4

  ctx.strokeStyle=COLORS.outline
  ctx.fillStyle=COLORS.cloud

  ctx.beginPath()
  ctx.arc(this.x,this.y,this.radius,0,Math.PI*2)
  ctx.fill()
  ctx.stroke()

  let dx=mouse.x-this.x
  let dy=mouse.y-this.y

  let d=Math.hypot(dx,dy)

  let maxOffset=this.radius-this.pupil-6

  let ox=0
  let oy=0

  if(d>0 && this.pupilAnim===0){

   ox=(dx/d)*maxOffset
   oy=(dy/d)*maxOffset

  }

  ctx.fillStyle=COLORS.pupil

  ctx.beginPath()
  ctx.arc(this.x+ox,this.y+oy,this.pupil,0,Math.PI*2)
  ctx.fill()

  ctx.save()

  ctx.beginPath()
  ctx.arc(this.x,this.y,this.radius,0,Math.PI*2)
  ctx.clip()

  if(this.lid>0){

   ctx.fillStyle=COLORS.eyelid

   ctx.fillRect(
    this.x-this.radius,
    this.y-this.radius,
    this.radius*2,
    this.radius*2*this.lid
   )

  }

  ctx.restore()
 }
}

/* ================= EVENTS ================= */

canvas.addEventListener("mousemove",e=>{

 mouse.x=e.clientX
 mouse.y=e.clientY

 if(mouse.down){

  clouds.forEach(c=>{

   let dx=c.x-mouse.x
   let dy=c.y-mouse.y

   let d=Math.hypot(dx,dy)

   let influence=c.r*3

   if(d<influence){

    let f=(influence-d)/influence

    c.vx+=(dx/d)*f*2
    c.vy+=(dy/d)*f*2

   }

  })

 }

})

canvas.addEventListener("mousedown",()=>mouse.down=true)
canvas.addEventListener("mouseup",()=>mouse.down=false)

canvas.addEventListener("click",e=>{

 if(!eye) return

 let d=Math.hypot(e.clientX-eye.x,e.clientY-eye.y)

 if(d<eye.radius){

  eyeClicks++

  eye.pupilAnim=30

  if(eyeClicks>=10){

   destroyEye()

  }

 }

})

/* ================= SPAWN ================= */

function spawnCloud(){

 if(!eye) return
 if(clouds.length >= maxCloudCount()) return

 /* spawn inside wide horizontal ellipse */

 const angle = Math.random() * Math.PI * 2

 const ellipseX = 220
 const ellipseY = 110

 const r = 0.4 + Math.random() * 0.6

 const x = eye.x + Math.cos(angle) * ellipseX * r
 const y = eye.y + Math.sin(angle) * ellipseY * r

 clouds.push(new Cloud(x,y,60))
}

function explodeEye(x,y){

 for(let i=0;i<8;i++){

  let a=i*(Math.PI*2/8)

  stars.push(new Star(x,y,a))

 }

 for(let i=0;i<40;i++){

  particles.push(new Particle(x,y))

 }

}

function destroyEye(){

 explodeEye(eye.x,eye.y)

 clouds.forEach(c=>c.fade=true)

 eye=null

 setTimeout(respawnEye,2000)

}

function respawnEye(){

 orbitClouds=[]
 orbitTimer=0
 orbitActive=true

 eyeClicks=0

 eye=new Eye()

 for(let i=0;i<4;i++){

  orbitClouds.push(new OrbitCloud(i*Math.PI/2))

 }

}

/* ================= LOOP ================= */

function update(){

 if(eye){

  orbitClouds.forEach(c=>c.update())

 }

 clouds.forEach((c,i)=>{

  c.update()

  if(c.alpha<=0) clouds.splice(i,1)

 })

 stars.forEach((s,i)=>{

  s.update()

  if(s.life<=0) stars.splice(i,1)

 })

 particles.forEach((p,i)=>{

  p.update()

  if(p.life<=0) particles.splice(i,1)

 })

 if(eye){

  eye.update()

 }

 /* delay cloud spawning until orbit clouds finish growing */

 if(!orbitActive && orbitClouds.length>0 && orbitClouds[0].size>=orbitClouds[0].baseSize){
 cloudSpawnTimer++
 }
 else{
 cloudSpawnTimer=0
 }

 if(cloudSpawnTimer>30){

  spawnCloud()

  cloudSpawnTimer=0

 }

}

function draw(){

 ctx.clearRect(0,0,canvas.width,canvas.height)

 orbitClouds.forEach(c=>c.draw())

 clouds.forEach(c=>c.draw())

 stars.forEach(s=>s.draw())

 particles.forEach(p=>p.draw())

 if(eye) eye.draw()

}

function loop(){

 update()
 draw()

 requestAnimationFrame(loop)

}

/* ================= INIT ================= */

function resetScene(){

 clouds=[]
 orbitClouds=[]
 particles=[]
 stars=[]

 setTimeout(respawnEye,800)

}

resetScene()
loop()


document.getElementById("refreshBtn").onclick=()=>location.reload()

</script>
</body>
</html>
